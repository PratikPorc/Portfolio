# Google Sheets Integration Configuration
# For Contact Form backend (/api/contact)

# 1. Provide the ID of the Google Sheet (found in the URL: https://docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit)
GOOGLE_SHEET_ID="your_google_sheet_id_here"

# 2. Provide the Client Email from your Google Cloud Service Account JSON key
GOOGLE_CLIENT_EMAIL="your-service-account@your-project-id.iam.gserviceaccount.com"

# 3. Provide the Private Key from your Google Cloud Service Account JSON key
# Note: Ensure it includes the "-----BEGIN PRIVATE KEY-----" and "-----END PRIVATE KEY-----"
# If your environment parses newlines incorrectly, you can replace newlines with \n
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_LONG_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
